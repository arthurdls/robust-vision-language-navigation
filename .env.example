# Copy to .env.local (recommended for secrets) or .env, then fill in values.
# The rvln package loads .env then .env.local on startup (.env.local overrides).
# Usage: source .env.local

# ── API Keys ──────────────────────────────────────────────────────────────────
# Required for all LLM / VLM calls (planner, SubgoalConverter, GoalAdherenceMonitor).
# The paper uses gpt-4o for text-only planning and gpt-5.4 for VLM calls.
export OPENAI_API_KEY="sk-..."

# ── Simulation Networking ─────────────────────────────────────────────────────
# These control where the pipeline connects to the OpenVLA server and UnrealCV.
# All three default to localhost; override them when running across machines.
export SERVER_HOST="127.0.0.1"       # OpenVLA server IP (default: 127.0.0.1)
export SIM_HOST="127.0.0.1"          # UnrealCV simulator IP (default: 127.0.0.1)
export SIM_PORT="9000"               # UnrealCV listen port (default: 9000)

# ── Unreal Environment Path ──────────────────────────────────────────────────
# Path to the Unreal simulation binary (set by tools/download_simulator.py).
# Defaults to runtime/unreal/ if unset.
export UnrealEnv="/path/to/rvln-adls/runtime/unreal"
