!results/condition0/**/subgoal_03_go_to_the_black_car/diary_artifacts/
!results/condition0/**/subgoal_03_go_to_the_black_car/diary_artifacts/**
# Exclude raw / uncompressed hardware media; commit compressed versions only
results/hardware/20260507_*.mp4
results/hardware/replay_synced.mp4
results/hardware/replay_synced_2x.mp4
results/hardware/playback.mp4

